# Ghost-Tracker Root Gitignore

# Dependencies
node_modules/
.yarn/
!?.yarn/patches
!?.yarn/plugins
!?.yarn/releases
!?.yarn/sdks
!?.yarn/versions

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Xcode / iOS
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*?.xcworkspace/userdata/
*?.xccheckout
DerivedData
*.hmap
*.ipa
*.xcuserstate
**/.xcode.env.local
Pods/

# Android
.gradle/
local.properties
*.iml
*.hprof
.cxx/
*.keystore
!debug.keystore
.kotlin/
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Debug / Logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# OS
.DS_Store
*.pem
Thumbs.db

# Environment
.env*.local

# Build artifacts
*.jsbundle
/coverage
*.tsbuildinfo

# Metro
.metro-health-check*
